---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import DimLine from '../components/DimLine.astro';

// Handled by the server-rendered API route at src/pages/api/contact.ts,
// which relays submissions through Resend to conner@listeraero.com. See
// that file for the required environment variables.
const formAction = '/api/contact';

const projectTypes = [
  'Structural analysis / FEA',
  'FAA certification support',
  'CAD & drawings',
  'Tooling & manufacturing',
  'Other',
];
---

<Layout
  title="Request a Quote"
  description="Describe the part or project below. Expect a quick response."
>
  <section class="contact-intro">
    <div class="wrap">
      <p class="eyebrow">Request a Quote</p>
      <h1 class="contact-intro__headline">Describe the part or project.<br />Expect a quick response.</h1>
    </div>
  </section>

  <section class="contact-form-section">
    <div class="wrap">
      <DimLine />
      <form
        id="quote-form"
        class="quote-form"
        method="POST"
        action={formAction}
        data-success="Request sent. A response will follow shortly."
      >
        <div class="quote-form__trap" aria-hidden="true">
          <label for="company_website">Leave this field blank</label>
          <input id="company_website" name="company_website" type="text" tabindex="-1" autocomplete="off" />
        </div>

        <div class="quote-form__row">
          <label for="name">Name <span class="req">*</span></label>
          <input id="name" name="name" type="text" autocomplete="name" required />
        </div>

        <div class="quote-form__row">
          <label for="company">Company</label>
          <input id="company" name="company" type="text" autocomplete="organization" />
        </div>

        <div class="quote-form__row">
          <label for="email">Email <span class="req">*</span></label>
          <input id="email" name="email" type="email" autocomplete="email" required />
        </div>

        <div class="quote-form__row">
          <label for="phone">Phone</label>
          <input id="phone" name="phone" type="tel" autocomplete="tel" />
        </div>

        <div class="quote-form__row">
          <label for="project_type">Project type</label>
          <select id="project_type" name="project_type">
            {projectTypes.map((type) => (
              <option value={type}>{type}</option>
            ))}
          </select>
          <p class="quote-form__hint">Pick the closest match. Cover the rest in the message.</p>
        </div>

        <div class="quote-form__row quote-form__row--full">
          <label for="message">Message <span class="req">*</span></label>
          <textarea id="message" name="message" rows="6" required></textarea>
        </div>

        <div class="quote-form__actions">
          <button type="submit" class="btn btn-solid">Send request</button>
          <p class="quote-form__fallback">
            Prefer email? Write to <a href="mailto:conner@listeraero.com">conner@listeraero.com</a>.
          </p>
        </div>

        <div class="quote-form__status" role="status" aria-live="polite"></div>
      </form>
    </div>
  </section>
</Layout>

<style>
  .contact-intro {
    padding-bottom: 1rem;
  }

  .contact-intro__headline {
    font-size: clamp(1.9rem, 4vw, 2.7rem);
    max-width: 26ch;
    margin-top: 0.9rem;
  }

  .quote-form {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem 2rem;
    max-width: 760px;
  }

  .quote-form__row {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .quote-form__trap {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .quote-form__row--full {
    grid-column: 1 / -1;
  }

  label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-structure);
  }

  .req {
    color: var(--color-accent-ink);
  }

  .quote-form__hint {
    margin: 0;
    font-size: 0.82rem;
    color: var(--color-titanium);
  }

  input,
  select,
  textarea {
    font-family: var(--font-body);
    font-size: 1rem;
    padding: 0.75rem 0.9rem;
    background: var(--color-base-raised);
    border: 1px solid var(--color-hairline-strong);
    border-radius: var(--radius);
    color: var(--color-ink);
  }

  textarea {
    resize: vertical;
  }

  input:focus,
  select:focus,
  textarea:focus {
    border-color: var(--color-accent-ink);
  }

  .quote-form__actions {
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .quote-form__fallback {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-titanium);
  }

  .quote-form__fallback a {
    color: var(--color-accent-ink);
  }

  .quote-form__status {
    grid-column: 1 / -1;
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  .quote-form__status[data-state='success'] {
    color: #2f6f4e;
  }

  .quote-form__status[data-state='error'] {
    color: var(--color-accent-ink);
  }

  @media (max-width: 700px) {
    .quote-form {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.getElementById('quote-form') as HTMLFormElement | null;
  const status = form?.querySelector('.quote-form__status') as HTMLElement | null;

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!status) return;

    const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    submitButton?.setAttribute('disabled', 'true');
    status.dataset.state = '';
    status.textContent = 'Sending…';

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      const data = await response.json().catch(() => null);

      if (response.ok && data?.ok) {
        status.dataset.state = 'success';
        status.textContent = form.dataset.success || 'Request sent. A response will follow shortly.';
        form.reset();
      } else {
        // Field-level errors (e.g. an invalid email) are worth showing verbatim —
        // they tell the visitor what to fix. Anything else (a misconfigured
        // form, a mail-service outage) is a problem on this end, not theirs,
        // so stay generic rather than surfacing internals.
        const detail = data?.fieldErrors?.length
          ? data.fieldErrors.map((e: { message: string }) => e.message).join('. ')
          : null;
        status.dataset.state = 'error';
        status.textContent = detail
          ? `Couldn't send that: ${detail}. Fix that and try again, or email conner@listeraero.com directly.`
          : "Couldn't send that. Something's wrong on this end. Email conner@listeraero.com directly instead.";
      }
    } catch {
      status.dataset.state = 'error';
      status.textContent = "Couldn't reach the server. Email conner@listeraero.com directly instead.";
    } finally {
      submitButton?.removeAttribute('disabled');
    }
  });
</script>
