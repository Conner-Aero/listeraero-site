---
// The site's signature motif: a dimension line with arrow terminators,
// borrowed from engineering drawings. Used as connective tissue between sections.
interface Props {
  label?: string;
  class?: string;
}
const { label, class: className } = Astro.props;
---

<div class:list={['dimline', className]} role="presentation" aria-hidden="true">
  <svg class="dimline__cap" viewBox="0 0 16 16" width="16" height="16">
    <path d="M14 3 L2 8 L14 13" fill="none" stroke="currentColor" stroke-width="1.25" />
  </svg>
  <span class="dimline__rule"></span>
  {label && <span class="dimline__label">{label}</span>}
  {label && <span class="dimline__rule"></span>}
  <svg class="dimline__cap" viewBox="0 0 16 16" width="16" height="16">
    <path d="M2 3 L14 8 L2 13" fill="none" stroke="currentColor" stroke-width="1.25" />
  </svg>
</div>

<style>
  .dimline {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-titanium);
    width: 100%;
  }

  .dimline__rule {
    flex: 1;
    height: 1px;
    background: var(--color-hairline);
  }

  .dimline__cap {
    flex-shrink: 0;
  }

  .dimline__label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    white-space: nowrap;
    color: var(--color-titanium);
  }
</style>
