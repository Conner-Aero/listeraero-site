---
// Section-view corner marks, drafting-style crop brackets framing a content block.
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<div class:list={['framed', className]}>
  <svg class="framed__mark framed__mark--tl" viewBox="0 0 20 20" aria-hidden="true"><path d="M0 14 V0 H14" fill="none" stroke="currentColor" stroke-width="1.25" /></svg>
  <svg class="framed__mark framed__mark--tr" viewBox="0 0 20 20" aria-hidden="true"><path d="M6 0 H20 V14" fill="none" stroke="currentColor" stroke-width="1.25" /></svg>
  <svg class="framed__mark framed__mark--bl" viewBox="0 0 20 20" aria-hidden="true"><path d="M0 6 V20 H14" fill="none" stroke="currentColor" stroke-width="1.25" /></svg>
  <svg class="framed__mark framed__mark--br" viewBox="0 0 20 20" aria-hidden="true"><path d="M6 20 H20 V6" fill="none" stroke="currentColor" stroke-width="1.25" /></svg>
  <div class="framed__content">
    <slot />
  </div>
</div>

<style>
  .framed {
    position: relative;
    padding: 1.1rem;
    color: var(--color-accent);
  }

  .framed__mark {
    position: absolute;
    width: 20px;
    height: 20px;
  }

  .framed__mark--tl { top: 0; left: 0; }
  .framed__mark--tr { top: 0; right: 0; }
  .framed__mark--bl { bottom: 0; left: 0; }
  .framed__mark--br { bottom: 0; right: 0; }

  .framed__content {
    color: var(--color-ink);
  }
</style>
