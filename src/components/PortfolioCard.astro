---
import PlaceholderArt from './PlaceholderArt.astro';

interface Props {
  title: string;
  tags: string[];
  description: string;
  patternId: string;
}
const { title, tags, description, patternId } = Astro.props;
---

<article class="port-card">
  <PlaceholderArt label={title} patternId={patternId} />
  <div class="port-card__body">
    <ul class="port-card__tags">
      {tags.map((tag) => (
        <li>{tag}</li>
      ))}
    </ul>
    <h3 class="port-card__title">{title}</h3>
    <p class="port-card__description">{description}</p>
  </div>
</article>

<style>
  .port-card {
    background: var(--color-base-raised);
    border: 1px solid var(--color-hairline);
    display: flex;
    flex-direction: column;
  }

  .port-card__body {
    padding: 1.4rem 1.5rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .port-card__tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.8rem;
    margin: 0;
    padding: 0;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent-ink);
  }

  .port-card__tags li:not(:last-child)::after {
    content: '\00b7';
    margin-left: 0.8rem;
    color: var(--color-hairline-strong);
  }

  .port-card__title {
    font-size: 1.2rem;
  }

  .port-card__description {
    margin: 0;
    color: var(--color-structure);
    font-size: 0.92rem;
  }
</style>
